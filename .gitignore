# Byte-compiled / optimized / DLL files
__pycache__/
*.py[cod]
*$py.class

# Distribution / packaging
dist/
build/
*.egg-info/
*.egg
.eggs/

# Virtual environments
.venv/
venv/
env/
ENV/

# Jupyter notebooks checkpoints
.ipynb_checkpoints/

# Data directories (recordings stored locally – never commit audio/keystroke data)
data/raw/*
data/processed/*
data/models/*
# Keep placeholder files so Git tracks the empty directories
!data/raw/.gitkeep
!data/processed/.gitkeep
!data/models/.gitkeep

# Logs
*.log
logs/

# OS artifacts
.DS_Store
Thumbs.db

# IDE settings
.vscode/
.idea/

# Coverage
.coverage
htmlcov/
.pytest_cache/

# MyPy
.mypy_cache/
